<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>上級編ヒント</title>

<style>
body {
  font-family: sans-serif;
  padding: 12px;
  background: #f5f5f5;
  font-size: 20px;
  line-height: 1.7;
}

.section {
  background: white;
  margin-bottom: 15px;
  padding: 12px;
  border-radius: 10px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

button {
  display: block;
  width: 100%;
  margin: 8px 0;
  padding: 18px;
  font-size: 20px;
  border: none;
  border-radius: 10px;
  background: #0078d4;
  color: white;
  cursor: pointer;
}

.hint {
  display: none;
  margin: 8px 0;
  padding: 12px;
  background: #e8f0fe;
  border-radius: 8px;
  word-break: break-word;
}

h1 {
  font-size: 28px;
  text-align: center;
}

h2 {
  font-size: 24px;
}
</style>
</head>

<body>

<h1>謎解きヒント（上級編）</h1>

<div class="section">

  <h2>上級編ヒント</h2>

  <div id="advanced"></div>

  <button onclick="toggleHint('a-final')">最終問題</button>

  <div id="a-final" class="hint">

    <b>ヒント1：</b>
    今まで出てきた6問の謎の答えで埋めましょう。<br>
    できる動物の名前は、鳥類が２つ、爬虫類が１つ、哺乳類が１つです。
    <br><br>

    <button onclick="
      document.getElementById('a-h2').style.display='block';
      this.style.display='none';
    ">
      次のヒントを見る
    </button>

    <div id="a-h2" style="display:none; margin-top:8px;">
      <b>ヒント2：</b>
      表紙の会場MAPにはイラストが描かれております。実際にその場所へ行ってみましょう。<br>
      ※見つからない場合は謎解きのスタッフまで。
      <br><br>

      <button onclick="
        document.getElementById('a-h3').style.display='block';
        this.style.display='none';
      ">
        次のヒントを見る
      </button>
    </div>

    <div id="a-h3" style="display:none; margin-top:8px;">
      <b>ヒント3：</b>
      その場所に行き、引き出しの中を探してみましょう。<br>
      最終問題にはいくつか指示がありますが、どの指示を見るべきかは６問の答えを埋めた時に分かっているはずです。<br>
      それ以外の指示は無視しましょう。
      <br><br>

      <button onclick="
        document.getElementById('a-h4').style.display='block';
        this.style.display='none';
      ">
        次のヒントを見る
      </button>
    </div>

    <div id="a-h4" style="display:none; margin-top:8px;">
      <b>ヒント4：</b>
      星の上半分と下半分が問題用紙にあります。<br>
      左側の枠線とツライチになっているのを目印に山折りにして２つの星を同時に２つ作りましょう。
      <br><br>

      <button onclick="
        document.getElementById('a-h5').style.display='block';
        this.style.display='none';
      ">
        次のヒントを見る
      </button>
    </div>

    <div id="a-h5" style="display:none; margin-top:8px;">
      <b>ヒント5：</b>
      次はゴールからスタートまで行く必要があります。<br>
      見るべきは◇マークでワープする迷路です。<br>
      迷路の形が変わっているため先ほどとは異なるルートを通る必要がありそうです。
      <br><br>

      <button onclick="
        document.getElementById('a-h6').style.display='block';
        this.style.display='none';
      ">
        次のヒントを見る
      </button>

      <div id="a-h6" style="display:none; margin-top:8px;">
        <b>ヒント6：</b>
        赤い◇は右下の解答欄に、青い◇は引き出しの中の最終問題にあります。<br>
        通った文字を順に並べて読んでみましょう。<br>
        最後の答えは8文字の言葉です。(ここから先は自分の力で解きましょう。)
      </div>
    </div>

  </div>
</div>

<script>
function toggleHint(id) {
  const el = document.getElementById(id);
  el.style.display = el.style.display === 'block' ? 'none' : 'block';
}

const advancedTitles = [
  "紙を配置する謎",
  "白い図形がある謎",
  "数字のパネルの謎",
  "うし すし と書いてある謎",
  "「たらい」「走路」と書いてある謎",
  "迷路の謎"
];

const advancedHints = [
  [
    "赤い枠は「すいむ」から「きんむ」に、青い枠は「かせき」から「きそく」に変化する法則があるようです。赤い枠は曜日ではない別の法則があるようです。",
    "「すい」の次に「きん」が来るもの、それは惑星に関係しているようです。<br>また青い枠は50音表を思い浮かべるといいかもしれません。"
  ],
  [
    "分かる食べ物から作って候補を減らしましょう。",
    "「から」は「しめ」につながり、「かす」は「たー」につながります。"
  ],
  [
    "丸の中の数字に11が多く使われているのがポイントです。",
    "この条件で合計で11になる組み合わせは全部で４通りあります。合計が11になる組み合わせに入れない数字は何でしょうか。"
  ],
  [
    "矢印のほうこうに読むと、それぞれ「とし」「うた」になるようです。マスに当てはめると、？？しと？うた？？？？…となります。",
    "全部で12個あるものの名前が並んでいます。１年ごとに変わるものです。"
  ],
  [
    "テープで何か貼ってあった痕跡があります。<br>どこかに落ちてしまったのでしょうか？(会場内を探す必要はありません)",
    "どうやら遊び方の辺りに落ちてしまっていたようです。<br>書かれたものの4,2文字目を読むと走路の文字が拾えます。"
  ],
  [
    "同じ色の◇にワープするルールのようです。まずピンクの◇からワープしましょう。",
    "ピンク色の◇は枠線の外にあるようです。ルールにもある通り黒線を横切らずに最短でゴールに向かいましょう。"
  ]
];

function createQuestions(containerId, prefix, hints, titles) {

  const container = document.getElementById(containerId);

  for (let i = 1; i <= hints.length; i++) {

    const btn = document.createElement('button');
    btn.textContent = titles[i - 1];
    btn.onclick = () => toggleHint(prefix + i);

    const hint = document.createElement('div');
    hint.id = prefix + i;
    hint.className = 'hint';

    hint.innerHTML =
      "<b>ヒント1：</b>" + hints[i - 1][0] +
      "<br><br>" +
      "<button onclick=\"document.getElementById('" + prefix + "h2_" + i + "').style.display='block';this.style.display='none';\">さらにヒントを見る</button>" +
      "<div id='" + prefix + "h2_" + i + "' style='display:none; margin-top:8px;'>" +
      "<b>ヒント2：</b>" + hints[i - 1][1] +
      "</div>";

    container.appendChild(btn);
    container.appendChild(hint);
  }
}

createQuestions('advanced', 'a', advancedHints, advancedTitles);
</script>

</body>
</html>
